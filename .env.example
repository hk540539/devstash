# Neon PostgreSQL — use the dev branch connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth
AUTH_URL="http://localhost:3000"
AUTH_SECRET="your-auth-secret"

# GitHub OAuth (https://github.com/settings/developers)
AUTH_GITHUB_ID="your-github-oauth-app-id"
AUTH_GITHUB_SECRET="your-github-oauth-app-secret"

# Resend (https://resend.com)
RESEND_API_KEY="re_your_api_key"

# Set to false to skip email verification during development
EMAIL_VERIFICATION_ENABLED=false

# Upstash Redis — used for auth rate limiting (https://console.upstash.com)
UPSTASH_REDIS_REST_URL="https://your-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# Supabase S3-compatible storage
SUPABASE_S3_ACCESS_ID="dummyId"
SUPABASE_S3_SECRET_ACCESS_KEY="dummy_key"
SUPABASE_S3_BUCKET="your-bucket-name"
SUPABASE_S3_ENDPOINT="https://your-project-ref.storage.supabase.co/storage/v1/s3"
SUPABASE_S3_REGION="your-region"
